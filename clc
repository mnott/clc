"""

import ast
import json
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

import typer
from rich.console import Console
from rich.table import Table
from rich import print as rprint

app = typer.Typer(
    name="clc",
    help=(
        "Claude Code startup manager.\n\n"
        "Run with no subcommand to launch claude with the current effective config.\n"
        "Env vars are layered: user settings.json < global mysettings.json < local mysettings.json < CLI flags.\n\n"
        "Examples:\n"
        "  clc                       # launch with current config\n"
        "  clc -v 2.1.96             # pin version for this run only\n"
        "  clc -m opus               # disable 1M-token context for this run\n"
        "  clc --dry-run             # preview the command that would run\n"
        "  clc config show           # list every managed parameter + effective value\n"
        "  clc config set CLAUDE_CODE_MODEL opus --local   # persist to this project\n"
    ),
    no_args_is_help=False,
    invoke_without_command=True,
    pretty_exceptions_enable=False,
)
config_app = typer.Typer(
    help=(
        "Manage persistent config across three layers.\n\n"
        "Precedence (later overrides earlier): user < global < local. CLI flags beat all.\n"
        "  user   → ~/.claude/settings.json  (env block)\n"
        "  global → <clc script dir>/mysettings.json\n"
        "  local  → ./.claude/mysettings.json\n"
    )
)
app.add_typer(config_app, name="config")

console = Console()


@app.callback(invoke_without_command=True)
def main(
    ctx: typer.Context,
    dry_run: bool = typer.Option(False, "--dry-run", "-n", help="Print the command and env that would be executed, then exit."),
    effort: Optional[str] = typer.Option(None, "--effort", "-e", metavar="LEVEL", help="Effort level: low | medium | high | max. No default — omit to leave unset."),
    max_tokens: Optional[str] = typer.Option(None, "--max-tokens", "-t", metavar="TOKENS", help="Max output tokens. Accepts shorthand (4k, 16k, 32k, 64k) or an exact integer."),
    model: Optional[str] = typer.Option(None, "--model", "-m", metavar="MODEL", help="Model to launch. Plain 'opus'/'sonnet' DISABLES the 1M-token context; add [1m] to enable it. Examples: opus, opus[1m], sonnet, haiku."),
    skip_permissions: Optional[bool] = typer.Option(None, "--skip-perms/--no-skip-perms", help="Pass --dangerously-skip-permissions to claude. Default is off unless DANGEROUSLY_SKIP_PERMISSIONS is set in config."),
    subagent: Optional[str] = typer.Option(None, "--subagent", "-s", metavar="SUBAGENT", help="Override CLAUDE_CODE_SUBAGENT_MODEL for this run: haiku | sonnet | opus."),
    version: Optional[str] = typer.Option(None, "--version", "-v", metavar="VERSION", help="Pin a Claude Code release via npx (e.g. 2.1.96). Empty = use local binary at ~/.local/bin/claude."),
    resume: Optional[str] = typer.Option(None, "--resume", "-r", metavar="SESSION_ID", help="Resume a prior session by id (passed to claude as --resume)."),
):
    """Launch claude when no subcommand is supplied. All options are runtime-only (not persisted)."""
    if ctx.invoked_subcommand is None:
        code = _run_claude(
            effort=effort,
            max_tokens=_parse_tokens(max_tokens) if max_tokens else None,
            model=model,
            skip_permissions=skip_permissions,
            subagent=subagent,
            version=version,
            dry_run=dry_run,
            resume=resume,
        )
        if code:
            raise typer.Exit(code)

# ── paths ──────────────────────────────────────────────────────────────────

SCRIPT_DIR = Path(__file__).resolve().parent
SETTINGS_PATH = Path.home() / ".claude" / "settings.json"
GLOBAL_MYSETTINGS_PATH = SCRIPT_DIR / "mysettings.json"
LOCAL_MYSETTINGS_PATH = Path.cwd() / ".claude" / "mysettings.json"
PARAMS_PATH = SCRIPT_DIR / "params.json"

# ── parameter registry ─────────────────────────────────────────────────────
# The registry lives in params.json next to this script so descriptions and
# example values can be edited without touching code. Add a new parameter by
# appending an entry to params.json — no Python change required.

def _read_json_dict(path: Path) -> dict:
    """Return the JSON object at `path`, or `{}` for missing/empty files.

    Only raises on real syntax errors in non-empty content. Missing or
    whitespace-only files are treated as "no overrides" rather than fatal.
    """
    if not path.exists():
        return {}
    text = path.read_text().strip()
    if not text:
        return {}
    return json.loads(text)


def _load_params() -> dict[str, dict[str, str]]:
    return _read_json_dict(PARAMS_PATH)

PARAMS: dict[str, dict[str, str]] = _load_params()

# ── defaults ───────────────────────────────────────────────────────────────

def _load_defaults() -> dict[str, str]:
    """Load global mysettings.json verbatim. Used only by `config reset`."""
    return _read_json_dict(GLOBAL_MYSETTINGS_PATH)

DEFAULTS: dict[str, str] = _load_defaults()

# ── helpers ────────────────────────────────────────────────────────────────

def _load_settings() -> dict:
    return _read_json_dict(SETTINGS_PATH)


def _save_settings(data: dict) -> None:
    SETTINGS_PATH.write_text(json.dumps(data, indent=2) + "\n")


def _get_env_block(data: dict) -> dict:
    return data.setdefault("env", {})


def _parse_tokens(value: str) -> int:
    """Parse token shorthand: 4k→4096, 16k→16384, 32k→32768, 64k→65536, or exact int."""
    value = value.lower().strip()
    if value.endswith("k"):
        return int(value[:-1]) * 1024
    return int(value)


# ── config helpers ────────────────────────────────────────────────────────

def _load_local_mysettings() -> dict[str, str]:
    """Load local ./.claude/mysettings.json if it exists."""
    return _read_json_dict(LOCAL_MYSETTINGS_PATH)


def _save_local_mysettings(data: dict) -> None:
    """Save to local ./.claude/mysettings.json (creates dir if needed)."""
    LOCAL_MYSETTINGS_PATH.parent.mkdir(parents=True, exist_ok=True)
    LOCAL_MYSETTINGS_PATH.write_text(json.dumps(data, indent=2) + "\n")


def _load_global_mysettings() -> dict[str, str]:
    """Load global mysettings.json."""
    return _read_json_dict(GLOBAL_MYSETTINGS_PATH)


def _save_global_mysettings(data: dict) -> None:
    """Save to global mysettings.json."""
    GLOBAL_MYSETTINGS_PATH.write_text(json.dumps(data, indent=2) + "\n")


def _effective_config() -> dict[str, tuple[str, str]]:
    """Resolve every PARAMS key against all three layers.

    Precedence (later overrides earlier):
        user settings.json  <  global mysettings.json  <  local mysettings.json

    Returns a dict mapping key -> (value, source). A key absent from every
    layer is omitted. A key set to "" in some layer is kept (with that source);
    callers that treat empty as "skip env var" still do so via their own check,
    but empty is preserved here so explicit-empty overrides are visible.
    """
    user = _get_env_block(_load_settings())
    glob = _load_global_mysettings()
    local = _load_local_mysettings()

    merged: dict[str, tuple[str, str]] = {}
    for key in PARAMS:
        if key in user:
            merged[key] = (user[key], "user")
        if key in glob:
            merged[key] = (glob[key], "global")
        if key in local:
            merged[key] = (local[key], "local")
    return merged


# ── config subcommands ─────────────────────────────────────────────────────

@config_app.command("show")
def config_show(
    extras: bool = typer.Option(False, "--extras", "-x", help="Also list non-managed env keys found in user settings.json."),
    verbose: bool = typer.Option(False, "--verbose", "-v", help="Print per-parameter descriptions and example values below the table."),
):
    """Show every managed parameter across all layers with description and effective source.

    Unconfigured parameters are still listed so you can see which knobs exist
    (e.g. set CLAUDE_CODE_MODEL=opus to disable the 1M-token context window).
    """
    global_defaults = _load_global_mysettings()
    local_settings = _load_local_mysettings()
    user_settings = _get_env_block(_load_settings())
    effective = _effective_config()

    console.print("[bold]Config layers[/bold] [dim](later overrides earlier; CLI flags beat all)[/dim]:")
    console.print(f"  1. [yellow]user[/yellow]     {SETTINGS_PATH}  [dim](env block)[/dim]")
    console.print(f"  2. [dim]global[/dim]   {GLOBAL_MYSETTINGS_PATH}  [dim](clc defaults)[/dim]")
    local_status = "[green](exists)[/green]" if LOCAL_MYSETTINGS_PATH.exists() else "[dim](not found — create with `clc setup`)[/dim]"
    console.print(f"  3. [cyan]local[/cyan]    {LOCAL_MYSETTINGS_PATH}  {local_status}")
    console.print()

    table = Table(title="clc managed parameters (values per layer)", show_header=True, header_style="bold")
    table.add_column("Key", style="bold", no_wrap=True)
    table.add_column("user", style="yellow")
    table.add_column("global", style="dim")
    table.add_column("local", style="cyan")
    table.add_column("effective", style="bold green")
    table.add_column("src", style="dim", no_wrap=True)

    unset_marker = "[dim](unset)[/dim]"
    for key in sorted(PARAMS):
        u = user_settings.get(key, "")
        g = global_defaults.get(key, "")
        l = local_settings.get(key, "")
        if key in effective:
            eff_val, src = effective[key]
        else:
            eff_val, src = "", "-"
        table.add_row(
            key,
            u if u != "" else "-",
            g if g != "" else "-",
            l if l != "" else "-",
            eff_val if eff_val else unset_marker,
            src,
        )

    console.print(table)

    if verbose:
        console.print()
        console.print("[bold]Descriptions[/bold]:")
        for key, meta in sorted(PARAMS.items()):
            console.print(f"  [bold]{key}[/bold]")
            console.print(f"    {meta['desc']}")
            console.print(f"    [dim]examples:[/dim] {meta['examples']}")

    if extras:
        managed = set(PARAMS.keys())
        extra_keys = sorted(k for k in user_settings if k not in managed)
        if extra_keys:
            console.print()
            xt = Table(title="Other keys in user settings.json (not managed by clc)", show_header=True, header_style="dim")
            xt.add_column("Key", style="bold")
            xt.add_column("Value", style="yellow")
            for k in extra_keys:
                xt.add_row(k, str(user_settings[k]))
            console.print(xt)

    console.print()
    console.print("[dim]Precedence: CLI flags > local > global > user.  Use `clc config set KEY VALUE --local|--user|--global`.[/dim]")


@config_app.command("set")
def config_set(
    key: str = typer.Argument(..., help="Env var key (e.g. CLAUDE_CODE_MODEL). See `clc config show` for the list."),
    value: str = typer.Argument(..., help="Value to set. Use an empty string to clear (e.g. ''). For examples per key, see `clc config show`."),
    local: bool = typer.Option(False, "--local", "-l", help="Write to ./.claude/mysettings.json (per-project, highest precedence among persisted layers)."),
    user: bool = typer.Option(False, "--user", "-u", help="Write to ~/.claude/settings.json env block (baseline)."),
    glob: bool = typer.Option(False, "--global", "-g", help="Write to the clc-provided mysettings.json next to the script."),
):
    """Persist a config value in one of the three layers.

    Default target: --local if ./.claude/mysettings.json already exists, otherwise --user.
    Override with one of --local / --user / --global (mutually exclusive).
    """
    # Determine target
    if sum([local, user, glob]) > 1:
        rprint("[red]Specify only one of --local, --user, --global[/red]")
        raise typer.Exit(1)

    if glob:
        data = _load_global_mysettings()
        old = data.get(key, "")
        data[key] = value
        _save_global_mysettings(data)
        target = "global"
    elif user:
        settings = _load_settings()
        env = _get_env_block(settings)
        old = env.get(key, "")
        env[key] = value
        _save_settings(settings)
        target = "user"
    elif local or LOCAL_MYSETTINGS_PATH.exists():
        data = _load_local_mysettings()
        old = data.get(key, "")
        data[key] = value
        _save_local_mysettings(data)
        target = "local"
    else:
        # Default to user settings.json
        settings = _load_settings()
        env = _get_env_block(settings)
        old = env.get(key, "")
        env[key] = value
        _save_settings(settings)
        target = "user"

    rprint(f"[green]Set[/green] {key} in [cyan]{target}[/cyan]: [dim]{old or '-'}[/dim] -> [bold]{value}[/bold]")


@config_app.command("unset")
def config_unset(
    key: str = typer.Argument(..., help="Env var key to remove from the selected layer."),
    local: bool = typer.Option(False, "--local", "-l", help="Remove from ./.claude/mysettings.json."),
    user: bool = typer.Option(False, "--user", "-u", help="Remove from ~/.claude/settings.json env block."),
    glob: bool = typer.Option(False, "--global", "-g", help="Remove from the clc-provided mysettings.json."),
):
    """Remove a key from a single layer.

    Default target: --local if ./.claude/mysettings.json exists, otherwise --user.
    Removing from one layer lets a lower layer (or harness default) take effect again.
    """
    if sum([local, user, glob]) > 1:
        rprint("[red]Specify only one of --local, --user, --global[/red]")
        raise typer.Exit(1)

    if glob:
        data = _load_global_mysettings()
        if key not in data:
            rprint(f"[yellow]{key}[/yellow] not in global mysettings.json")
            raise typer.Exit(0)
        del data[key]
        _save_global_mysettings(data)
        target = "global"
    elif user:
        settings = _load_settings()
        env = _get_env_block(settings)
        if key not in env:
            rprint(f"[yellow]{key}[/yellow] not in user settings.json")
            raise typer.Exit(0)
        del env[key]
        _save_settings(settings)
        target = "user"
    elif local or LOCAL_MYSETTINGS_PATH.exists():
        data = _load_local_mysettings()
        if key not in data:
            rprint(f"[yellow]{key}[/yellow] not in local mysettings.json")
            raise typer.Exit(0)
        del data[key]
        _save_local_mysettings(data)
        target = "local"
    else:
        settings = _load_settings()
        env = _get_env_block(settings)
        if key not in env:
            rprint(f"[yellow]{key}[/yellow] not in user settings.json")
            raise typer.Exit(0)
        del env[key]
        _save_settings(settings)
        target = "user"

    rprint(f"[green]Removed[/green] {key} from [cyan]{target}[/cyan]")


@config_app.command("reset")
def config_reset(
    yes: bool = typer.Option(False, "--yes", "-y", help="Skip the confirmation prompt."),
):
    """Reset managed keys in ~/.claude/settings.json to the clc-provided global defaults.

    Only the user layer is touched — global and local mysettings.json are left alone.
    """
    if not yes:
        typer.confirm("Reset managed env keys in user settings.json to clc global defaults?", abort=True)
    data = _load_settings()
    env = _get_env_block(data)
    for key, val in DEFAULTS.items():
        env[key] = val
    _save_settings(data)
    rprint("[green]Reset managed keys in user settings.json to clc global defaults.[/green]")


# ── setup command ─────────────────────────────────────────────────────────

@app.command()
def setup(
    force: bool = typer.Option(False, "--force", "-f", help="Overwrite ./.claude/mysettings.json if it already exists."),
):
    """Create ./.claude/mysettings.json seeded with the clc global defaults.

    Use this to start a project-level override file; edit it afterwards or use
    `clc config set KEY VALUE --local` to update individual keys.
    """
    target_dir = Path.cwd() / ".claude"
    target_file = target_dir / "mysettings.json"

    if target_file.exists() and not force:
        rprint(f"[yellow]{target_file} already exists.[/yellow] Use --force to overwrite.")
        raise typer.Exit(1)

    # Create .claude dir if needed
    target_dir.mkdir(parents=True, exist_ok=True)

    # Copy global mysettings.json
    if not GLOBAL_MYSETTINGS_PATH.exists():
        rprint(f"[red]Global mysettings.json not found at {GLOBAL_MYSETTINGS_PATH}[/red]")
        raise typer.Exit(1)

    global_defaults = _read_json_dict(GLOBAL_MYSETTINGS_PATH)
    target_file.write_text(json.dumps(global_defaults, indent=2) + "\n")

    rprint(f"[green]Created[/green] {target_file}")
    rprint("[dim]Edit this file to customize settings for this project.[/dim]")


# ── install / uninstall commands ─────────────────────────────────────────

@app.command()
def install(
    force: bool = typer.Option(False, "--force", "-f", help="Overwrite an existing symlink without prompting."),
):
    """Run uv sync and symlink clc into ~/.local/bin/ (or /usr/local/bin/ with sudo).

    From a fresh clone this is all you need — uv manages the virtualenv automatically
    via the script's shebang. Requires uv on PATH (brew install uv on macOS).
    """
    if not shutil.which("uv"):
        rprint("[red]uv not found on PATH.[/red]  Install it first:  brew install uv")
        raise typer.Exit(1)

    if not shutil.which("npx"):
        rprint("[yellow]Warning:[/yellow] npx not found on PATH (or resolves to a dead symlink).")
        rprint("[dim]clc's default CLAUDE_CODE_VERSION pins a release via npx, so you'll need Node.js:[/dim]")
        rprint("[dim]  macOS:          brew install node[/dim]")
        rprint("[dim]  Debian/Ubuntu:  curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash - && sudo apt install -y nodejs[/dim]")
        rprint("[dim]Or run with a local claude binary instead:  clc config unset CLAUDE_CODE_VERSION --global[/dim]")

    rprint(f"[dim]Running uv sync in {SCRIPT_DIR}...[/dim]")
    subprocess.run(["uv", "sync"], cwd=SCRIPT_DIR, check=True)

    script = SCRIPT_DIR / "clc"
    local_bin = Path.home() / ".local" / "bin"
    usr_local_bin = Path("/usr/local/bin")

    path_dirs = [Path(p) for p in os.environ.get("PATH", "").split(":") if p]

    if local_bin in path_dirs or not path_dirs:
        target = local_bin / "clc"
        use_sudo = False
    elif usr_local_bin in path_dirs:
        rprint(f"[yellow]~/.local/bin is not on PATH but /usr/local/bin is.[/yellow]")
        if sys.stdin.isatty() and typer.confirm(f"Install to {usr_local_bin}/clc (requires sudo)?", default=False):
            target = usr_local_bin / "clc"
            use_sudo = True
        else:
            target = local_bin / "clc"
            use_sudo = False
            rprint(f"[dim]Using {local_bin} anyway. Add it to PATH:[/dim]  export PATH=\"$HOME/.local/bin:$PATH\"")
    else:
        target = local_bin / "clc"
        use_sudo = False
        rprint(f"[dim]~/.local/bin is not on PATH. After install, add it:[/dim]  export PATH=\"$HOME/.local/bin:$PATH\"")

    if not use_sudo:
        target.parent.mkdir(parents=True, exist_ok=True)

    if target.exists() or target.is_symlink():
        if target.is_symlink():
            current = target.resolve()
            # Idempotent: if it already points at the same script, do nothing.
            if not force and current == script.resolve():
                rprint(f"[green]Already installed[/green]  {target}  ->  {current}")
                rprint("[dim]Nothing to do. Use --force to reinstall anyway.[/dim]")
                return
            rprint(f"[yellow]{target}[/yellow] already exists → [dim]{current}[/dim]")
            if not force:
                if not sys.stdin.isatty():
                    rprint("[red]Non-interactive; refusing to overwrite an existing symlink.[/red]")
                    rprint("[dim]Re-run with --force to replace it:  ./clc install --force[/dim]")
                    raise typer.Exit(1)
                if not typer.confirm("Replace it?", default=True):
                    raise typer.Exit(0)
        else:
            if not force:
                rprint(f"[red]{target} exists and is not a symlink.[/red] Use --force to overwrite.")
                raise typer.Exit(1)
        if use_sudo:
            subprocess.run(["sudo", "rm", "-f", str(target)], check=True)
        else:
            target.unlink()

    if use_sudo:
        subprocess.run(["sudo", "ln", "-sfn", str(script), str(target)], check=True)
    else:
        target.symlink_to(script)

    result = subprocess.run([str(target), "--help"], capture_output=True)
    ok = result.returncode == 0

    uv_version = subprocess.run(["uv", "--version"], capture_output=True, text=True).stdout.strip()
    rprint()
    rprint(f"[green]Installed[/green]  {script}  ->  {target}")
    rprint(f"  uv: {uv_version}")
    rprint(f"  verify: {'[green]ok[/green]' if ok else '[red]FAILED (--help returned nonzero)[/red]'}")
    if not ok:
        raise typer.Exit(1)


@app.command()
def uninstall(
    force: bool = typer.Option(False, "--force", "-f", help="Remove without prompting."),
):
    """Remove symlink(s) created by clc install.

    Checks both ~/.local/bin/clc and /usr/local/bin/clc. Only removes symlinks
    that point into this repo. The .venv/ directory is never touched.
    """
    candidates = [
        Path.home() / ".local" / "bin" / "clc",
        Path("/usr/local/bin/clc"),
    ]
    removed_any = False

    for target in candidates:
        if not target.exists() and not target.is_symlink():
            continue

        if not target.is_symlink():
            rprint(f"[yellow]{target}[/yellow] exists but is not a symlink — skipping.")
            continue

        resolved = target.resolve()
        points_here = str(resolved).startswith(str(SCRIPT_DIR))
        use_sudo = str(target).startswith("/usr/local")

        if points_here:
            if not force and sys.stdin.isatty():
                if not typer.confirm(f"Remove {target} -> {resolved}?", default=True):
                    continue
            # non-tty: default=True → proceed without prompting
        else:
            rprint(f"[yellow]{target}[/yellow] points to [dim]{resolved}[/dim] (outside this repo).")
            if not force:
                if not sys.stdin.isatty():
                    rprint(f"[dim]Non-interactive; skipping. Use --force to remove.[/dim]")
                    continue
                if not typer.confirm(f"Remove it anyway?", default=False):
                    continue

        if use_sudo:
            subprocess.run(["sudo", "rm", "-f", str(target)], check=True)
        else:
            target.unlink()
        rprint(f"[green]Removed[/green] {target}")
        removed_any = True

    if not removed_any:
        rprint("[dim]Nothing to remove.[/dim]")

    venv = SCRIPT_DIR / ".venv"
    if venv.exists():
        rprint(f"[dim].venv at {venv} was left in place. Remove manually if desired.[/dim]")


# ── run logic ─────────────────────────────────────────────────────────────

def _run_claude(
    effort: Optional[str] = None,
    model: Optional[str] = None,
    skip_permissions: Optional[bool] = None,
    subagent: Optional[str] = None,
    max_tokens: Optional[int] = None,
    sandbox: Optional[int] = None,
    user_type: Optional[str] = None,
    version: Optional[str] = None,
    dry_run: bool = False,
    prompt: Optional[str] = None,
    resume: Optional[str] = None,
    name_to_apply: Optional[str] = None,
) -> int:
    """Core logic to launch Claude Code. Returns the exit code (no internal sys.exit)."""

    # ── Resolve effective config (user < global < local) ──────────────────
    effective = _effective_config()

    # ── Resolve version: CLI > effective config > empty (use local binary) ──
    if version is None:
        version = effective.get("CLAUDE_CODE_VERSION", ("", ""))[0]

    # ── Resolve model: CLI > effective config > empty (harness default) ──
    if model is None:
        model = effective.get("CLAUDE_CODE_MODEL", ("", ""))[0]

    # ── Resolve skip_permissions: CLI > config > False ──────────────────
    if skip_permissions is None:
        cfg_val = effective.get("DANGEROUSLY_SKIP_PERMISSIONS", ("", ""))[0]
        if cfg_val != "":
            skip_permissions = cfg_val == "1"
        else:
            skip_permissions = False

    # ── Resolve effort: CLI > config > None (don't append flag) ─────────
    if effort is None:
        cfg_effort = effective.get("CLAUDE_CODE_EFFORT_LEVEL", ("", ""))[0]
        if cfg_effort != "":
            effort = cfg_effort

    # ── Validate effort only if one was actually requested ───────────────
    if effort:
        valid_efforts = {"low", "medium", "high", "max"}
        if effort not in valid_efforts:
            typer.echo(f"Invalid effort '{effort}'. Choose from: {', '.join(sorted(valid_efforts))}", err=True)
            raise typer.Exit(1)

    # ── Build env overrides from effective config, then CLI flags ─────────
    env_overrides: dict[str, str] = {}
    for key, (val, _src) in effective.items():
        if key in ("CLAUDE_CODE_VERSION", "CLAUDE_CODE_MODEL"):
            continue  # surfaced on the command line, not as env
        if PARAMS.get(key, {}).get("kind") == "internal":
            continue  # clc-internal params must not leak into the subprocess env
        if val != "":
            env_overrides[key] = val

    # Override with CLI flags
    if sandbox is not None:
        env_overrides["IS_SANDBOX"] = str(sandbox)
    if user_type is not None:
        env_overrides["USER_TYPE"] = user_type
    if subagent is not None:
        valid_models = {"haiku", "sonnet", "opus"}
        if subagent not in valid_models:
            typer.echo(f"Invalid subagent '{subagent}'. Choose from: {', '.join(sorted(valid_models))}", err=True)
            raise typer.Exit(1)
        env_overrides["CLAUDE_CODE_SUBAGENT_MODEL"] = subagent
    if max_tokens is not None:
        env_overrides["CLAUDE_CODE_MAX_OUTPUT_TOKENS"] = str(max_tokens)

    # ── Build command ─────────────────────────────────────────────────────
    if version:
        # Specific version via npx
        cmd = ["npx", f"@anthropic-ai/claude-code@{version}"]
        version_display = version
    else:
        # Local binary
        cmd = [str(Path.home() / ".local" / "bin" / "claude")]
        version_display = "local"

    if skip_permissions:
        cmd.append("--dangerously-skip-permissions")

    if model:
        cmd.extend(["--model", model])

    if effort:
        cmd.extend(["--effort", effort])

    # Prepend the `/Name <name>` slash command (the Name skill) so a fresh
    # session adopts the saved name automatically.
    _prompt_prefix = ""
    if name_to_apply:
        _prompt_prefix = f"/Name {name_to_apply}\n"

    if resume:
        # Allow a saved-session name (or list #) in place of a raw UUID.
        # UUIDs are 36 chars with 4 dashes; anything else → look up in registry.
        uuid_re = re.compile(r"^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$")
        if not uuid_re.match(resume):
            try:
                reg = _load_sessions_registry(_sessions_file())
                hit = _resolve_session(reg, resume)
                if hit:
                    uid = _entry_uuid(hit[1])
                    if uid:
                        resume = uid
            except Exception:
                pass
        cmd.extend(["--resume", resume])

    # ── Resolve default prompt: CLI arg > config, else send nothing ──────
    # The prompt is config-only: whatever DEFAULT_PROMPT resolves to is sent
    # verbatim. Absent from every layer (or explicit "") = no prompt argument.
    # The shipped global mysettings.json sets DEFAULT_PROMPT="go"; emptying or
    # removing it from every layer launches claude with no auto-prompt.
    if prompt is None:
        prompt = effective.get("DEFAULT_PROMPT", ("", ""))[0]
    combined_prompt = (_prompt_prefix + (prompt or "")).strip("\n")
    if combined_prompt:
        cmd.append(combined_prompt)

    # ── Merge env: process env + overrides (overrides win) ───────────────
    final_env = os.environ.copy()
    final_env.update(env_overrides)

    # ── Dry run: show the full resolved launch and exit ──────────────────
    # On a real launch we stay silent so claude's own UI takes over cleanly.
    if dry_run:
        model_display = model if model else "default"
        effort_display = effort if effort else "default"
        console.print(f"[bold cyan]clc[/bold cyan]")
        console.print(f"  [dim]version:[/dim] [bold]{version_display}[/bold]  [dim]model:[/dim] [bold]{model_display}[/bold]  [dim]effort:[/dim] [bold]{effort_display}[/bold]  [dim]skip-perms:[/dim] [bold]{skip_permissions}[/bold]")
        console.print(f"  [dim]env:[/dim]")
        for k, v in sorted(env_overrides.items()):
            console.print(f"    {k}=[bold]{v}[/bold]")
        cmd_str = " ".join(cmd)
        console.print(f"  [dim]$[/dim] {cmd_str}")
        console.print("[yellow]Dry run — not executing.[/yellow]")
        return 0

    # ── Preflight: verify the command exists (clean error beats a traceback) ─
    if not shutil.which(cmd[0]):
        if cmd[0] == "npx":
            rprint(f"[red]npx not found on PATH[/red] (or resolves to a dead symlink — e.g. stale /snap/bin/npx).")
            rprint("[dim]A pinned CLAUDE_CODE_VERSION requires Node.js.  Install it:[/dim]")
            rprint("[dim]  macOS:          brew install node[/dim]")
            rprint("[dim]  Debian/Ubuntu:  curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash - && sudo apt install -y nodejs[/dim]")
            rprint("[dim]  Or skip it:     clc config unset CLAUDE_CODE_VERSION --global[/dim]")
        else:
            rprint(f"[red]Command not found:[/red] {cmd[0]}")
            if cmd[0].endswith("/claude"):
                rprint("[dim]No local claude binary. Either install one at that path, or pin a version:[/dim]")
                rprint("[dim]  clc config set CLAUDE_CODE_VERSION 2.1.105 --global[/dim]")
        raise typer.Exit(127)

    # ── Execute ───────────────────────────────────────────────────────────
    # subprocess.run (not execvpe) so we can clean up the terminal after claude
    # exits — otherwise iTerm2 DA2 query replies (^[P>|iTerm2…) leak into the
    # next prompt when claude exits via an early error path without restoring
    # the TTY.
    try:
        result = subprocess.run(cmd, env=final_env)
    except KeyboardInterrupt:
        _cleanup_terminal()
        return 130
    _cleanup_terminal()
    return result.returncode


def _cleanup_terminal() -> None:
    """Restore the TTY and drain any pending terminal responses after claude exits.

    Claude's early-exit paths (e.g. `--resume` rejection) don't always reset the
    terminal mode, leaving DA1/DA2 query responses queued in stdin which then
    bleed into the next shell prompt. This combines:
      1. A short sleep so any in-flight terminal responses can arrive.
      2. An active read-drain on stdin (handles bytes that arrive after exec ends).
      3. termios flush (discards anything still queued at the kernel TTY layer).
      4. Writing terminal-reset escape sequences to undo alt-screen / bracketed paste / focus events.
    """
    if not sys.stdin.isatty():
        return
    try:
        import select
        import termios
        import time
        time.sleep(0.05)
        fd = sys.stdin.fileno()
        # Drain any input bytes already in the OS pipe buffer.
        while select.select([fd], [], [], 0)[0]:
            try:
                if not os.read(fd, 4096):
                    break
            except OSError:
                break
        termios.tcflush(fd, termios.TCIFLUSH)
        # Reset terminal state that claude's TUI may have left active.
        # ?25h cursor on, ?1049l leave alt-screen, ?2004l no bracketed paste,
        # ?1004l no focus events, 0m reset SGR.
        sys.stdout.write("\x1b[?25h\x1b[?1049l\x1b[?2004l\x1b[?1004l\x1b[0m")
        sys.stdout.flush()
    except Exception:
        pass


# ── doc command ───────────────────────────────────────────────────────────

def _render_params_table() -> str:
    rows = ["| Parameter | What it controls | Examples |",
            "|-----------|-----------------|---------|"]
    for key, meta in sorted(PARAMS.items()):
        desc = meta.get("desc", "").replace("|", r"\|")
        examples = meta.get("examples", "").replace("|", r"\|")
        rows.append(f"| `{key}` | {desc} | {examples} |")
    return "\n".join(rows)


SHELL_INIT_SNIPPET = r"""# clc shell wrapper — add to ~/.zshrc or ~/.bashrc:  eval "$(clc shell-init)"
#
# Wraps `clc` so that `clc sessions cd NAME` actually changes the parent
# shell's cwd (a child process can't change its parent's cwd; only a shell
# function can). All other invocations pass straight through to real clc.
clc() {
    if [[ "$1" == "sessions" && "$2" == "cd" ]]; then
        local dir
        dir="$(command clc sessions cd "${@:3}" 2>/dev/null)"
        if [[ -n "$dir" && -d "$dir" ]]; then
            builtin cd "$dir"
            echo "-> $dir"
        else
            command clc sessions cd "${@:3}"
            return 1
        fi
    elif [[ "$1" == "sessions" && "$2" == "resume" ]]; then
        # Best-effort: shift the parent shell's cwd too, so when claude exits
        # the user lands in the session's directory rather than back where they were.
        # Identifier is the first non-flag arg after `resume`.
        local _arg _id=""
        for _arg in "${@:3}"; do
            case "$_arg" in
                -*) ;;
                *) _id="$_arg"; break ;;
            esac
        done
        if [[ -n "$_id" ]]; then
            local dir
            dir="$(command clc sessions cd "$_id" 2>/dev/null)"
            if [[ -n "$dir" && -d "$dir" ]]; then
                builtin cd "$dir"
            fi
        fi
        command clc "$@"
    else
        command clc "$@"
    fi
}
"""


@app.command(name="shell-init")
def shell_init():
    """Print shell functions (clccd / clcgo) for actually changing the parent shell's cwd.

    Add to ~/.zshrc or ~/.bashrc:  eval "$(clc shell-init)"
    """
    print(SHELL_INIT_SNIPPET)


@app.command()
def doc():
    """Print the module docstring as markdown (use: `clc doc > README.md`)."""
    src = Path(__file__).read_text()
    module_doc = (ast.get_docstring(ast.parse(src)) or "").strip()
    module_doc = module_doc.replace("{{PARAMS_COUNT}}", str(len(PARAMS)))
    module_doc = module_doc.replace("{{PARAMS_TABLE}}", _render_params_table())
    print(f"# clc\n\n{module_doc}")


