@app.command()
def run(
    effort: Optional[str] = typer.Option(None, "--effort", "-e", metavar="LEVEL", help="Effort level: low | medium | high | max."),
    max_tokens: Optional[str] = typer.Option(None, "--max-tokens", "-t", metavar="TOKENS", help="Max output tokens. Shorthand (4k, 16k, 32k, 64k) or an exact integer."),
    model: Optional[str] = typer.Option(None, "--model", "-m", metavar="MODEL", help="Model to launch. Plain 'opus'/'sonnet' DISABLES 1M context; add [1m] to enable it."),
    skip_permissions: Optional[bool] = typer.Option(None, "--skip-perms/--no-skip-perms", help="Toggle --dangerously-skip-permissions."),
    subagent: Optional[str] = typer.Option(None, "--subagent", "-s", metavar="SUBAGENT", help="Subagent model: haiku | sonnet | opus."),
    sandbox: Optional[int] = typer.Option(None, "--sandbox", metavar="0|1", help="Set IS_SANDBOX env var (1 = sandbox, 0 = not)."),
    user_type: Optional[str] = typer.Option(None, "--user-type", metavar="TYPE", help="Set USER_TYPE env var."),
    version: Optional[str] = typer.Option(None, "--version", "-v", metavar="VERSION", help="Pin a Claude Code release via npx (e.g. 2.1.96). Empty = local binary."),
    resume: Optional[str] = typer.Option(None, "--resume", "-r", metavar="SESSION_ID", help="Resume a prior session by id (passed to claude as --resume)."),
    dry_run: bool = typer.Option(False, "--dry-run", "-n", help="Print the command and env that would be executed, then exit."),
    prompt: Optional[str] = typer.Argument(None, help="Prompt to send as the first message. Defaults to 'go' (which the session hook routes to TODO.md)."),
):
    """Launch Claude Code with optional overrides. Overrides are runtime-only; persist with `clc config set`."""
    code = _run_claude(
        effort=effort,
        max_tokens=_parse_tokens(max_tokens) if max_tokens else None,
        model=model,
        skip_permissions=skip_permissions,
        subagent=subagent,
        sandbox=sandbox,
        user_type=user_type,
        version=version,
        dry_run=dry_run,
        prompt=prompt,
        resume=resume,
    )
    if code:
        raise typer.Exit(code)


